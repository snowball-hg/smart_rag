# ===== DeepSeek LLM 配置 =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# ===== Milvus 向量数据库配置 =====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_documents

# ===== Embedding 模型配置 =====
# 可选: "local" (本地 Sentence-Transformers) 或 "qwen" (千问 Embeddings API)
EMBEDDING_PROVIDER=local
# 本地模型名称 (EMBEDDING_PROVIDER=local 时生效)
# 推荐: BAAI/bge-large-zh-v1.5, shibing624/text2vec-base-chinese, BAAI/bge-base-zh-v1.5
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
LOCAL_EMBEDDING_MODEL_PATH=D:\project\AI\my_rag\models
# 千问 Embeddings API Key (EMBEDDING_PROVIDER=qwen 时生效)
QWEN_EMBEDDING_API_KEY=
QWEN_EMBEDDING_MODEL=text-embedding-v3

# ===== 文档分块配置 =====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ===== 检索配置 =====
TOP_K=5

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=logs/rag_system.log
